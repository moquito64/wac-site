---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';
---

<Layout>
  <main>
    <section class="hero">
      <Image src={logoImg} alt="Wolf and crow emblem" class="logo" width="180" loading="eager" />
      <p class="alias"><span>wolf</span> · <span>moquito64</span></p>
      <h1>Sebastian Javier Blanchette</h1>
      <p class="tagline">
        <span class="facet-artist">Artist</span>
        <span class="dot">·</span>
        <span class="facet-programmer">Programmer</span>
        <span class="dot">·</span>
        <span class="facet-brainiac">Brainiac</span>
        <span class="dot">·</span>
        <span class="facet-poet">Poet</span>
      </p>
      <nav class="hero-nav">
        <a href="#facets">What I do</a>
        <a href="#poetry">Poetry</a>
        <a href="#contact">Say hello</a>
      </nav>
    </section>

    <section class="about">
      <h2>About</h2>
      <p>
        I'm Sebastian — wolf to friends, <code>moquito64</code> on the wire. I spent over a decade
        in Hawaii building and securing technology for other people. These days I build for the
        love of the craft: code that works, art that bites, ideas that won't sit still, and poems
        that keep the vigil between all three.
      </p>
    </section>

    <section class="facets" id="facets">
      <h2>Four Faces</h2>
      <div class="facet-grid">
        <article class="facet" style="--accent: var(--pink)">
          <h3>Artist</h3>
          <p>
            Line, ink, and pixel. I draw what the wolf sees and the crow remembers — emblems,
            creatures, and worlds that didn't exist until they had to.
          </p>
        </article>
        <article class="facet" style="--accent: var(--green)">
          <h3>Programmer</h3>
          <p>
            Ten-plus years from bare metal to the cloud. Infrastructure, security, and software —
            I like systems I can take apart and code that earns its keep.
          </p>
        </article>
        <article class="facet" style="--accent: var(--sapphire)">
          <h3>Brainiac</h3>
          <p>
            Insatiably curious. Networks, ciphers, hardware, history, whatever's under the next
            rock. If it can be understood, I want to understand it twice.
          </p>
        </article>
        <article class="facet" style="--accent: var(--mauve)">
          <h3>Poet</h3>
          <p>
            Words are the oldest technology I maintain. I write verse the way I write code:
            nothing wasted, everything load-bearing.
          </p>
        </article>
      </div>
    </section>

    <section class="poetry" id="poetry">
      <h2>Vigil</h2>
      <blockquote class="poem">
        <p>
          The wolf keeps to the ridgeline,<br />
          the crow keeps to the wind;<br />
          one reads the earth by scent and bone,<br />
          one reads where light has thinned.
        </p>
        <p>
          I keep to neither kingdom —<br />
          I walk the seam between,<br />
          half hunger, half a pair of wings,<br />
          and everything I've seen.
        </p>
        <footer>— wolf</footer>
      </blockquote>
      <p class="poetry-more">
        More verse at <a href="https://shrtstry.com">shrtstry.com</a>
      </p>
    </section>
  </main>

  <footer class="site-footer" id="contact">
    <h2>Say hello</h2>
    <a class="contact-btn" href="mailto:sblanchette@wolfandcrow.tech">sblanchette@wolfandcrow.tech</a>
    <nav class="social">
      <a href="https://github.com/moquito64">GitHub</a>
      <a href="https://www.linkedin.com/in/sebastianblanchette/">LinkedIn</a>
      <a href="https://shrtstry.com">Poetry Blog</a>
    </nav>
    <p class="fine-print">&copy; 2026 Sebastian Javier Blanchette. All rights reserved.</p>
  </footer>
</Layout>

<style>
  main {
    max-width: 60rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 3.5rem 0;
  }

  h2 {
    font-size: 2rem;
    font-weight: 700;
    color: var(--lavender);
    letter-spacing: 0.04em;
    text-align: center;
    margin: 0 0 1.5rem;
  }

  /* Hero */
  .hero {
    min-height: 88vh;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 4rem 0 3rem;
    background:
      radial-gradient(ellipse 70% 50% at 50% 0%, rgba(203, 166, 247, 0.12), transparent 70%);
  }

  .logo {
    width: 180px;
    height: auto;
    margin-bottom: 1rem;
    filter: drop-shadow(0 0 24px rgba(137, 180, 250, 0.25));
  }

  .alias {
    font-family: var(--font-mono);
    font-size: 0.95rem;
    color: var(--muted);
    letter-spacing: 0.12em;
    margin: 0 0 0.25rem;
  }

  .alias span {
    color: var(--peach);
  }

  h1 {
    font-size: clamp(2.1rem, 6vw, 3.5rem);
    font-weight: 700;
    line-height: 1.15;
    margin: 0;
    background: linear-gradient(100deg, var(--blue), var(--mauve), var(--pink));
    -webkit-background-clip: text;
    background-clip: text;
    -webkit-text-fill-color: transparent;
    color: transparent;
  }

  .tagline {
    font-size: clamp(1rem, 2.5vw, 1.25rem);
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    margin: 1rem 0 0;
  }

  .tagline .dot {
    color: var(--surface2);
    margin: 0 0.35em;
  }

  .facet-artist { color: var(--pink); }
  .facet-programmer { color: var(--green); }
  .facet-brainiac { color: var(--sapphire); }
  .facet-poet { color: var(--mauve); }

  .hero-nav {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 1rem;
    margin-top: 2.5rem;
  }

  .hero-nav a {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
    padding: 0.6rem 1.4rem;
    border: 1px solid var(--surface1);
    border-radius: 999px;
    background: rgba(49, 50, 68, 0.5);
    transition: border-color 0.2s, transform 0.2s;
  }

  .hero-nav a:hover {
    border-color: var(--mauve);
    transform: translateY(-2px);
  }

  /* About */
  .about p {
    max-width: 42rem;
    margin: 0 auto;
    text-align: center;
    font-size: 1.1rem;
    color: var(--subtext);
  }

  .about code {
    font-family: var(--font-mono);
    font-size: 0.95em;
    color: var(--peach);
    background: var(--surface0);
    padding: 0.1em 0.4em;
    border-radius: 6px;
  }

  /* Facets */
  .facet-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(15rem, 1fr));
    gap: 1.25rem;
  }

  .facet {
    background: var(--mantle);
    border: 1px solid var(--surface0);
    border-top: 3px solid var(--accent);
    border-radius: 12px;
    padding: 1.5rem;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  .facet:hover {
    transform: translateY(-5px);
    box-shadow: 0 12px 28px rgba(17, 17, 27, 0.6);
  }

  .facet h3 {
    margin: 0 0 0.5rem;
    font-size: 1.2rem;
    color: var(--accent);
    letter-spacing: 0.05em;
  }

  .facet p {
    margin: 0;
    color: var(--subtext);
    font-size: 0.98rem;
  }

  /* Poetry */
  .poetry {
    text-align: center;
  }

  .poem {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: clamp(1.25rem, 3vw, 1.6rem);
    line-height: 1.7;
    color: var(--text);
    margin: 0 auto;
    max-width: 34rem;
    padding: 2rem 1.5rem;
    border-block: 1px solid var(--surface0);
  }

  .poem p {
    margin: 0 0 1.4em;
  }

  .poem footer {
    font-style: normal;
    font-family: var(--font-mono);
    font-size: 0.9rem;
    color: var(--muted);
  }

  .poetry-more {
    margin-top: 1.5rem;
    color: var(--subtext);
  }

  .poetry-more a {
    color: var(--mauve);
    text-decoration-color: var(--surface2);
  }

  /* Footer */
  .site-footer {
    text-align: center;
    padding: 3.5rem 1.5rem 2.5rem;
    background: var(--mantle);
    border-top: 1px solid var(--surface0);
    margin-top: 2rem;
  }

  .contact-btn {
    display: inline-block;
    font-family: var(--font-mono);
    font-weight: 600;
    color: var(--crust);
    background: var(--lavender);
    text-decoration: none;
    padding: 0.8rem 1.8rem;
    border-radius: 10px;
    transition: background 0.2s;
  }

  .contact-btn:hover {
    background: var(--blue);
  }

  .social {
    display: flex;
    justify-content: center;
    gap: 1.5rem;
    margin-top: 1.5rem;
  }

  .social a {
    color: var(--subtext);
    text-decoration: none;
    font-weight: 600;
    border-bottom: 2px solid var(--surface1);
    padding-bottom: 2px;
    transition: color 0.2s, border-color 0.2s;
  }

  .social a:hover {
    color: var(--blue);
    border-color: var(--blue);
  }

  .fine-print {
    margin-top: 2rem;
    font-size: 0.85rem;
    color: var(--muted);
  }
</style>
