---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
import logoImg from '../assets/logo.png';
---

<Layout>
  <main>
    <header class="hero">
      <Image src={logoImg} alt="Wolf and crow emblem" class="emblem" width="72" loading="eager" />
      <p class="kicker">wolf · moquito64</p>
      <h1>Sebastian Javier Blanchette</h1>
      <p class="role">IT Specialist — Systems Administrator — Programmer</p>
      <p class="statement">
        I build systems that keep working after everyone stops watching,
        and I'm drawn to the places where technology meets mythology,
        philosophy, and story.
      </p>
      <p class="motto">acta non verba</p>
    </header>

    <section id="about">
      <p class="section-label">I &nbsp;·&nbsp; About</p>
      <h2>A quiet practice</h2>
      <p>
        By trade I keep infrastructure alive: servers, networks, backups, the
        unglamorous machinery that everything else depends on. By temperament
        I'm analytical and introspective — I want to know not just how a
        system fails, but why people built it that way in the first place.
      </p>
      <p>
        Off the clock the practice continues at a different altitude: a home
        lab that never stops evolving, self-hosted services in place of rented
        ones, automation that buys back time, science fiction that spends it
        well. The thread through all of it is the same — take a thing apart,
        understand it honestly, put it back together better.
      </p>
    </section>

    <section id="craft">
      <p class="section-label">II &nbsp;·&nbsp; Craft</p>
      <h2>What I do</h2>
      <ol class="craft-list">
        <li>
          <span class="index">01</span>
          <div>
            <h3>Systems administration</h3>
            <p>Infrastructure that stays up, backed up, and boring — the highest compliment a system can earn.</p>
          </div>
        </li>
        <li>
          <span class="index">02</span>
          <div>
            <h3>Programming</h3>
            <p>Small, sharp tools and honest code. Nothing wasted, everything load-bearing.</p>
          </div>
        </li>
        <li>
          <span class="index">03</span>
          <div>
            <h3>Self-hosting &amp; home lab</h3>
            <p>Owning my own services end to end, because understanding a thing means running it yourself.</p>
          </div>
        </li>
        <li>
          <span class="index">04</span>
          <div>
            <h3>Automation</h3>
            <p>If it must be done twice, it should be done by a machine the third time.</p>
          </div>
        </li>
      </ol>
    </section>

    <section id="symbols">
      <p class="section-label">III &nbsp;·&nbsp; Symbols</p>
      <h2>A small bestiary</h2>
      <div class="symbol-grid">
        <article>
          <h3>The Wolf <span class="latin">lupus</span></h3>
          <p>Persistence. The patience to stay on a problem's trail long after it goes cold.</p>
        </article>
        <article>
          <h3>The Crow <span class="latin">corvus</span></h3>
          <p>Curiosity. The instinct to collect bright ideas from unrelated fields and see what they open.</p>
        </article>
        <article>
          <h3>The Mountain <span class="latin">mons</span></h3>
          <p>Reliability. Weather passes; the shape underneath does not move.</p>
        </article>
        <article>
          <h3>The North Star <span class="latin">stella polaris</span></h3>
          <p>Truth over hype. A fixed point to navigate by when everything else is trend.</p>
        </article>
      </div>
    </section>

    <section id="verse">
      <p class="section-label">IV &nbsp;·&nbsp; Verse</p>
      <h2>Vigil</h2>
      <blockquote class="poem">
        <p>
          The wolf keeps to the ridgeline,<br />
          the crow keeps to the wind;<br />
          one reads the earth by scent and bone,<br />
          one reads where light has thinned.
        </p>
        <p>
          I keep to neither kingdom —<br />
          I walk the seam between,<br />
          half hunger, half a pair of wings,<br />
          and everything I've seen.
        </p>
      </blockquote>
      <p class="verse-more">
        More at <a href="https://shrtstry.com">shrtstry.com</a>
      </p>
    </section>
  </main>

  <footer id="contact">
    <div class="footer-inner">
      <p class="section-label">V &nbsp;·&nbsp; Correspondence</p>
      <p class="footer-lede">
        The best way to reach me is the oldest one.
      </p>
      <p class="email">
        <a href="mailto:sblanchette@wolfandcrow.tech">sblanchette@wolfandcrow.tech</a>
      </p>
      <nav class="social">
        <a href="https://github.com/moquito64">GitHub</a>
        <a href="https://www.linkedin.com/in/sebastianblanchette/">LinkedIn</a>
        <a href="https://shrtstry.com">shrtstry</a>
      </nav>
      <p class="colophon">
        ✦ &nbsp;per aspera ad astra
        <span class="coords">α UMi · RA 02ʰ 31ᵐ · Dec +89° 15′</span>
      </p>
      <p class="fine-print">&copy; 2026 Sebastian Javier Blanchette</p>
    </div>
  </footer>
</Layout>

<style>
  main {
    max-width: 41rem;
    margin: 0 auto;
    padding: 0 1.5rem;
  }

  section {
    padding: 5.5rem 0 0;
  }

  h1,
  h2,
  h3 {
    font-family: var(--font-serif);
    font-weight: 500;
    line-height: 1.2;
    margin: 0;
  }

  h2 {
    font-size: 2rem;
    margin-bottom: 1.5rem;
  }

  section > p,
  #about p {
    color: var(--text-muted);
    margin: 0 0 1.25rem;
  }

  .section-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--text-faint);
    border-top: 1px solid var(--hairline);
    padding-top: 1.25rem;
    margin: 0 0 2rem;
  }

  /* Hero */
  .hero {
    min-height: 82vh;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 6rem 0 3rem;
  }

  .emblem {
    width: 72px;
    height: auto;
    margin-bottom: 2rem;
    opacity: 0.9;
  }

  .kicker {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    letter-spacing: 0.22em;
    color: var(--text-faint);
    margin: 0 0 1rem;
  }

  h1 {
    font-size: clamp(2.4rem, 6vw, 3.6rem);
    letter-spacing: -0.01em;
  }

  .role {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.08em;
    color: var(--starlight);
    margin: 1.25rem 0 0;
  }

  .statement {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.35rem;
    line-height: 1.6;
    color: var(--text);
    max-width: 34rem;
    margin: 2rem 0 0;
  }

  .motto {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    color: var(--brass);
    margin: 2.5rem 0 0;
  }

  /* Craft */
  .craft-list {
    list-style: none;
    margin: 0;
    padding: 0;
  }

  .craft-list li {
    display: flex;
    gap: 1.5rem;
    padding: 1.5rem 0;
    border-top: 1px solid var(--hairline);
  }

  .craft-list li:last-child {
    border-bottom: 1px solid var(--hairline);
  }

  .craft-list .index {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--text-faint);
    padding-top: 0.4rem;
  }

  .craft-list h3 {
    font-size: 1.25rem;
  }

  .craft-list p {
    margin: 0.35rem 0 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  /* Symbols */
  .symbol-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-top: 1px solid var(--hairline);
    border-left: 1px solid var(--hairline);
  }

  .symbol-grid article {
    border-right: 1px solid var(--hairline);
    border-bottom: 1px solid var(--hairline);
    padding: 1.75rem 1.5rem;
  }

  .symbol-grid h3 {
    font-size: 1.2rem;
    margin-bottom: 0.5rem;
  }

  .latin {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--brass);
    margin-left: 0.6em;
  }

  .symbol-grid p {
    margin: 0;
    color: var(--text-muted);
    font-size: 0.95rem;
  }

  @media (max-width: 600px) {
    .symbol-grid {
      grid-template-columns: 1fr;
    }
  }

  /* Verse */
  .poem {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.25rem;
    line-height: 1.8;
    color: var(--text);
    margin: 0;
    padding-left: 1.5rem;
    border-left: 1px solid var(--hairline-strong);
  }

  .poem p {
    margin: 0 0 1.4em;
  }

  .poem p:last-child {
    margin-bottom: 0;
  }

  .verse-more {
    font-size: 0.9rem;
    color: var(--text-faint);
    margin-top: 1.5rem;
  }

  /* Footer */
  footer {
    margin-top: 6rem;
    border-top: 1px solid var(--hairline);
    background: var(--ink-raised);
  }

  .footer-inner {
    max-width: 41rem;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 3rem;
  }

  .footer-inner .section-label {
    border-top: none;
    padding-top: 0;
    margin-bottom: 1.5rem;
  }

  .footer-lede {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 1.2rem;
    margin: 0 0 0.75rem;
  }

  .email {
    margin: 0 0 2rem;
  }

  .email a {
    font-family: var(--font-mono);
    font-size: 0.95rem;
  }

  .social {
    display: flex;
    gap: 2rem;
    margin-bottom: 3rem;
  }

  .social a {
    font-size: 0.9rem;
    color: var(--text-muted);
  }

  .colophon {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    letter-spacing: 0.14em;
    color: var(--brass);
    margin: 0 0 0.5rem;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem 1.5rem;
  }

  .coords {
    color: var(--text-faint);
  }

  .fine-print {
    font-size: 0.8rem;
    color: var(--text-faint);
    margin: 0;
  }
</style>
